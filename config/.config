CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_netgear_r6800=y

CONFIG_EXPERT=y
CONFIG_KERNEL_KALLSYMS=y
CONFIG_KERNEL_PRINTK=y
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_PACKAGE_irqbalance=y

CONFIG_PACKAGE_libwolfssl=y
CONFIG_WOLFSSL_HAS_AESGCM=y
CONFIG_WOLFSSL_HAS_CHACHA=y
CONFIG_WOLFSSL_HAS_POLY1305=y
CONFIG_PACKAGE_wpad-wolfssl=y
CONFIG_PACKAGE_libopenssl-wolfssl=y

CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_firewall4=y

CONFIG_PACKAGE_kmod-mt7615e=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_wireless-regdb=y

CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-wolfssl=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y

CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y

CONFIG_TARGET_ROOTFS_SQUASHFS=y
